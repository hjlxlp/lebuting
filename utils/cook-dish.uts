const BIZ_HOST = import.meta.env.VITE_BIZ_API_HOST as string
const HERMES_HOST = import.meta.env.VITE_HERMES_HOST as string
const BIZ_PORT = import.meta.env.VITE_BIZ_API_PORT as string

const API_PREFIX = '/api/cook-dish'

function resolveBizHost(): string {
	if (BIZ_HOST != null && BIZ_HOST.length > 0) {
		return BIZ_HOST
	}
	return HERMES_HOST
}

// #ifdef H5
export const BIZ_BASE_URL = '/biz-api'
// #endif
// #ifndef H5
export const BIZ_BASE_URL = 'http://' + resolveBizHost() + ':' + (BIZ_PORT != null && BIZ_PORT.length > 0 ? BIZ_PORT : '8181')
// #endif

export type CookDishFood = {
	id: number
	name: string
	type: string
	excluded: boolean
	note: string
}

export type CookDishRecord = {
	id: number
	food_id: number
	food_name: string
	food_type: string
	cooked_at: string
	meal: string
}

export type CookDishSpinResult = {
	food: CookDishFood
	pool_size: number
}

export type CookDishStat = {
	food_id: number
	label: string
	total: number
	month_count: number
	last_cooked_at: string
}

export type CookDishStatsSummary = {
	month: string
	total_count: number
	ranking: CookDishStat[]
}

export const COOK_DISH_TYPES = ['家常菜', '快手菜', '硬菜', '汤羹', '凉菜', '烘焙', '素菜', '下饭菜', '其他']

type ApiPayload = UTSJSONObject
type HttpMethod = 'GET' | 'POST' | 'PUT' | 'PATCH'
type ApiEnvelope = {
	code: number
	message: string
	dataText: string
}

function apiHeader(): UTSJSONObject {
	return {
		'Content-Type': 'application/json'
	} as UTSJSONObject
}

function readMessage(raw: UTSJSONObject): string {
	const msg = raw['message']
	if (msg == null) {
		return '请求失败'
	}
	return '' + msg
}

function stringifyField(value: any | null): string {
	if (value == null) {
		return ''
	}
	return JSON.stringify(value)
}

function parsePayloadObject(text: string): ApiPayload | null {
	if (text.length == 0) {
		return null
	}
	return JSON.parse(text) as ApiPayload
}

function readPayloadArrayFromText(text: string): ApiPayload[] {
	const rows: ApiPayload[] = []
	if (text.length == 0) {
		return rows
	}
	const parsed = JSON.parse(text)
	if (parsed == null) {
		return rows
	}
	const arr = parsed as ApiPayload[]
	for (let i = 0; i < arr.length; i++) {
		rows.push(arr[i])
	}
	return rows
}

function parseFood(raw: ApiPayload): CookDishFood {
	return {
		id: raw['id'] as number,
		name: raw['name'] as string,
		type: raw['type'] as string,
		excluded: raw['excluded'] as boolean,
		note: raw['note'] as string
	}
}

function parseRecord(raw: ApiPayload): CookDishRecord {
	return {
		id: raw['id'] as number,
		food_id: raw['food_id'] as number,
		food_name: raw['food_name'] as string,
		food_type: raw['food_type'] as string,
		cooked_at: raw['cooked_at'] as string,
		meal: raw['meal'] as string
	}
}

function parseStat(raw: ApiPayload): CookDishStat {
	return {
		food_id: raw['food_id'] as number,
		label: raw['label'] as string,
		total: raw['total'] as number,
		month_count: raw['month_count'] as number,
		last_cooked_at: raw['last_cooked_at'] as string
	}
}

function parseFoodListFromText(text: string): CookDishFood[] {
	const rows = readPayloadArrayFromText(text)
	const list: CookDishFood[] = []
	for (let i = 0; i < rows.length; i++) {
		list.push(parseFood(rows[i]))
	}
	return list
}

function parseRecordListFromText(text: string): CookDishRecord[] {
	const rows = readPayloadArrayFromText(text)
	const list: CookDishRecord[] = []
	for (let i = 0; i < rows.length; i++) {
		list.push(parseRecord(rows[i]))
	}
	return list
}

function buildFoodsPath(excluded: boolean | null): string {
	if (excluded == null) {
		return API_PREFIX + '/foods'
	}
	const flag = excluded ? 'true' : 'false'
	return API_PREFIX + '/foods?excluded=' + flag
}

function requestEnvelope(method: HttpMethod, path: string, body: UTSJSONObject | null): Promise<ApiEnvelope> {
	return new Promise((resolve, reject) => {
		uni.request<UTSJSONObject>({
			url: BIZ_BASE_URL + path,
			method: method,
			header: apiHeader(),
			data: body,
			timeout: 15000,
			success: (res) => {
				if (res.statusCode != 200 || res.data == null) {
					reject('请求失败: ' + res.statusCode)
					return
				}
				const raw = res.data!
				const code = raw['code'] as number
				if (code != 0) {
					reject(readMessage(raw))
					return
				}
				const envelope: ApiEnvelope = {
					code: code,
					message: readMessage(raw),
					dataText: stringifyField(raw['data'])
				}
				resolve(envelope)
			},
			fail: (err) => {
				reject(err.errMsg)
			}
		})
	})
}

export function cookDishLabel(food: CookDishFood): string {
	return food.name + ' · ' + food.type
}

export function cookDishRecordLabel(record: CookDishRecord): string {
	return record.food_name + ' · ' + record.food_type
}

export function cookDishMealLabel(meal: string): string {
	if (meal == 'breakfast') return '早餐'
	if (meal == 'lunch') return '午餐'
	if (meal == 'dinner') return '晚餐'
	return '加餐'
}

export function listCookDishFoods(excluded: boolean | null = null): Promise<CookDishFood[]> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', buildFoodsPath(excluded), null).then((envelope: ApiEnvelope) => {
			resolve(parseFoodListFromText(envelope.dataText))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function getCookDishFood(id: number): Promise<CookDishFood | null> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', API_PREFIX + '/foods/' + id, null).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)
			if (data == null) {
				resolve(null)
				return
			}
			resolve(parseFood(data))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function createCookDishFood(name: string, type: string, note: string = ''): Promise<CookDishFood> {
	const body = {
		'name': name,
		'type': type,
		'note': note
	} as UTSJSONObject
	return new Promise((resolve, reject) => {
		requestEnvelope('POST', API_PREFIX + '/foods', body).then((envelope: ApiEnvelope) => {
			resolve(parseFood(parsePayloadObject(envelope.dataText)!))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function updateCookDishFood(id: number, name: string, type: string, note: string): Promise<CookDishFood | null> {
	const body = {
		'name': name,
		'type': type,
		'note': note
	} as UTSJSONObject
	return new Promise((resolve, reject) => {
		requestEnvelope('PUT', API_PREFIX + '/foods/' + id, body).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)
			if (data == null) {
				resolve(null)
				return
			}
			resolve(parseFood(data))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function setCookDishExcluded(id: number, excluded: boolean): Promise<CookDishFood | null> {
	const body = {
		'excluded': excluded
	} as UTSJSONObject
	return new Promise((resolve, reject) => {
		requestEnvelope('PATCH', API_PREFIX + '/foods/' + id + '/exclude', body).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)
			if (data == null) {
				resolve(null)
				return
			}
			resolve(parseFood(data))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function getCookDishWheelPool(): Promise<CookDishFood[]> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', API_PREFIX + '/wheel/pool', null).then((envelope: ApiEnvelope) => {
			resolve(parseFoodListFromText(envelope.dataText))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function spinCookDishWheel(): Promise<CookDishSpinResult> {
	return new Promise((resolve, reject) => {
		requestEnvelope('POST', API_PREFIX + '/wheel/spin', null).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)!
			const foodRaw = parsePayloadObject(stringifyField(data['food']))!
			const result: CookDishSpinResult = {
				food: parseFood(foodRaw),
				pool_size: data['pool_size'] as number
			}
			resolve(result)
		}).catch((err) => {
			reject(err)
		})
	})
}

export function addCookDishRecord(foodId: number): Promise<CookDishRecord> {
	const body = {
		'food_id': foodId,
		'source': 'wheel'
	} as UTSJSONObject
	return new Promise((resolve, reject) => {
		requestEnvelope('POST', API_PREFIX + '/records', body).then((envelope: ApiEnvelope) => {
			resolve(parseRecord(parsePayloadObject(envelope.dataText)!))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function listCookDishRecords(): Promise<CookDishRecord[]> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', API_PREFIX + '/records', null).then((envelope: ApiEnvelope) => {
			resolve(parseRecordListFromText(envelope.dataText))
		}).catch((err) => {
			reject(err)
		})
	})
}

export function getCookDishMonthCount(foodId: number): Promise<number> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', API_PREFIX + '/stats/food/' + foodId, null).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)!
			resolve(data['month_count'] as number)
		}).catch((err) => {
			reject(err)
		})
	})
}

export function getCookDishStatsSummary(): Promise<CookDishStatsSummary> {
	return new Promise((resolve, reject) => {
		requestEnvelope('GET', API_PREFIX + '/stats/summary', null).then((envelope: ApiEnvelope) => {
			const data = parsePayloadObject(envelope.dataText)!
			const rankingRaw = readPayloadArrayFromText(stringifyField(data['ranking']))
			const ranking: CookDishStat[] = []
			for (let i = 0; i < rankingRaw.length; i++) {
				ranking.push(parseStat(rankingRaw[i]))
			}
			const summary: CookDishStatsSummary = {
				month: data['month'] as string,
				total_count: data['total_count'] as number,
				ranking: ranking
			}
			resolve(summary)
		}).catch((err) => {
			reject(err)
		})
	})
}
