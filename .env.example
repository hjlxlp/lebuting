# 复制为 .env 后填写真实值：cp .env.example .env
# 修改 .env 后执行：node scripts/sync-android-config.mjs
# 云打包前必须执行 sync，生成 nativeResources/android/res/xml/network_security_config.xml
# 勿将 *.example.xml 放入 nativeResources（Android 资源名不允许含点号）

VITE_HERMES_HOST=x.x.x.x
VITE_HERMES_PORT=xxxx
VITE_HERMES_API_KEY=your-api-key-xxx
# 业务 API 主机：真机填台式机局域网 IP（ipconfig）；仅本机 H5 可用 127.0.0.1
VITE_BIZ_API_HOST=x.x.x.x
VITE_BIZ_API_PORT=xxxx
