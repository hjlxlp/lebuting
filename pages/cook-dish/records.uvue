<template>
	<view class="page">
		<scroll-view class="list" scroll-y="true">
			<view v-if="items.length == 0" class="empty">
				<text class="empty-text">还没有记录，转盘选中后点「记一笔」</text>
			</view>
			<view v-for="(item, index) in items" :key="index" class="row">
				<view class="row-left">
					<text class="row-label">{{ item.label }}</text>
					<text class="row-time">{{ item.timeText }}</text>
				</view>
				<text class="row-meal">{{ item.mealText }}</text>
			</view>
		</scroll-view>

		<cook-dish-tab-bar current="records"></cook-dish-tab-bar>
	</view>
</template>

<script setup lang="uts">
	import { listCookDishRecords, cookDishRecordLabel, cookDishMealLabel, type CookDishRecord } from '../../utils/cook-dish.uts'

	type Row = {
		label: string
		timeText: string
		mealText: string
	}

	const items = ref<Row[]>([])

	function loadList() {
		listCookDishRecords().then((list: CookDishRecord[]) => {
			const rows: Row[] = []
			for (let i = 0; i < list.length; i++) {
				const r = list[i]
				rows.push({
					label: cookDishRecordLabel(r),
					timeText: r.cooked_at,
					mealText: cookDishMealLabel(r.meal)
				})
			}
			items.value = rows
		})
	}

	onShow(() => {
		loadList()
	})
</script>

<style>
	.page {
		flex: 1;
		flex-direction: column;
		background-color: #f5f5f5;
	}

	.list {
		flex: 1;
		padding: 12px 16px;
	}

	.row {
		flex-direction: row;
		align-items: center;
		background-color: #ffffff;
		border-radius: 10px;
		padding: 14px 12px;
		margin-bottom: 8px;
	}

	.row-left {
		flex: 1;
		flex-direction: column;
	}

	.row-label {
		font-size: 16px;
		color: #333333;
		margin-bottom: 4px;
	}

	.row-time {
		font-size: 12px;
		color: #999999;
	}

	.row-meal {
		font-size: 13px;
		color: #34a853;
		padding: 4px 10px;
		background-color: #e6f4ea;
		border-radius: 12px;
	}

	.empty {
		padding: 60px 20px;
		align-items: center;
	}

	.empty-text {
		font-size: 14px;
		color: #999999;
		text-align: center;
	}
</style>
